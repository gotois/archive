  "private": false,
  "type": "module",
  "scripts": {
    "dev": "cross-env QUASAR_DEBUG=true quasar dev -m pwa",
    "dev:apk": "bubblewrap install",
    "build": "quasar c && quasar build -m pwa && cp public/_redirects dist/pwa/ && cp public/_headers dist/pwa/ && cp public/.well-known/assetlinks.json dist/pwa/.well-known/",
    "build:apk": "bubblewrap build",
    "fingerprint": "bubblewrap fingerprint generateAssetLinks --output=\"public/.well-known/assetlinks.json\"",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test": "echo \"No test specified\" && exit 0"
  },
